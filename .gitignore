# ─── Node / npm ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Environment / secrets ──────────────────────────────────────────────────
.env
.env.local
.env.*.local
# .env.example is safe to commit — contains only key names, no values
!.env.example
frontend/.env.local
frontend/.env.*.local
!frontend/.env.example

# ─── Hardhat ────────────────────────────────────────────────────────────────
artifacts/
cache/
typechain-types/
dist/

# ─── Rust / Cargo ────────────────────────────────────────────────────────────
rust-contracts/*/target/
rust-contracts/*/Cargo.lock

# ─── Next.js ────────────────────────────────────────────────────────────────
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/

# ─── TypeScript build info ───────────────────────────────────────────────────
*.tsbuildinfo

# ─── Jest / coverage ────────────────────────────────────────────────────────
coverage/
frontend/coverage/
test/results/gas-report.txt
# test/results/onchain-test-results.md is kept — it records AGT-04 on-chain results

# ─── Deployment artefacts ────────────────────────────────────────────────────
# deployments/paseo/addresses.json is kept — canonical contract registry
deployments/paseo/deploy.log

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ─── Vercel ──────────────────────────────────────────────────────────────────
.vercel

# ─── Misc ────────────────────────────────────────────────────────────────────
*.pid
*.pid.lock
*.seed

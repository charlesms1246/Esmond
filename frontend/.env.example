# frontend/.env.example
# Copy to .env.local and fill in values from deployments/paseo/addresses.json
# This file is safe to commit — contains only key names, no secrets.

# ─── Contract Addresses ───────────────────────────────────────────────────────
NEXT_PUBLIC_PAYROLL_VAULT_ADDRESS=
NEXT_PUBLIC_CONDITIONAL_ESCROW_ADDRESS=
NEXT_PUBLIC_SUBSCRIPTION_MANAGER_ADDRESS=
NEXT_PUBLIC_ACTIVE_SCHEDULER_ADDRESS=
NEXT_PUBLIC_MOCK_ERC20_ADDRESS=

# ─── Network Configuration ────────────────────────────────────────────────────
NEXT_PUBLIC_PASEO_RPC_URL=https://testnet-passet-hub-eth-rpc.polkadot.io
NEXT_PUBLIC_PASEO_WS_URL=wss://passet-hub-rpc.polkadot.io

# ─── Optional: Analytics / Error tracking ─────────────────────────────────────
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

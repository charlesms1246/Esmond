# .env.example — copy to .env and fill in values
# NEVER commit .env — it is in .gitignore

# Your deployer wallet private key (with or without 0x prefix)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Paseo (Polkadot Hub Testnet) RPC endpoints
PASEO_RPC_URL=https://testnet-passet-hub-eth-rpc.polkadot.io
PASEO_WS_URL=wss://passet-hub-rpc.polkadot.io

# Set to "true" to generate gas report after tests
REPORT_GAS=false
